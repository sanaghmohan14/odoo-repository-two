<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <record id="action_attendance_list_management" model="ir.actions.act_window">

        <field name="name">Absentees List</field>
        <field name="res_model">day.wise.attendances</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_by_date': 1}</field>
    </record>

    <record id="attendance_form" model="ir.ui.view">
        <field name="name">Attendance Form</field>
        <field name="model">day.wise.attendances</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="date"/>
<!--                        <field name="check_in"/>-->
<!--                        <field name="check_out"/>-->
                    </group>
                </sheet>
<!--                  <chatter/>-->
            </form>
        </field>
    </record>

    <record id="attendance_list_tree" model="ir.ui.view" >
        <field name="name">Attendance list tree</field>
        <field name="model">day.wise.attendances</field>
        <field name="arch" type="xml">
            <list>
                          <field name="employee_id"/>
<!--                        <field name="date"/>-->
<!--                        <field name="check_in"/>-->
<!--                        <field name="check_out"/>-->

            </list>
        </field>
    </record>



    <record id="absentees_list_search_views" model="ir.ui.view">
        <field name="name">absentees.list.management.view.search</field>
        <field name="model">day.wise.attendances</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <filter name="check_in" string="filter by check IN" />
                <filter name="group_by_employees" string="employees" context="{'group_by':'employee_id'}"/>
<!--                <filter name="today" string="filter by today" domain="['check_in','=',context_today()]"/>-->
            </search>
        </field>
    </record>


    <record id="ir_cron_absentees_list" model="ir.cron">
        <field name="name">absentees</field>
        <field name="model_id" ref="model_day_wise_attendances"/>
        <field name="code">model.generate_absentees()</field>
<!--        <field name="user_id" ref="base.user_root"/>-->
        <field name='interval_number'>1</field>
        <field name='interval_type'>minutes</field>
        <field name="active">True</field>
        <field name="state">code</field>
    </record>



</odoo>