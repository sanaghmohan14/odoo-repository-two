<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <record id="action_attendance_list_management" model="ir.actions.act_window">

        <field name="name">Absentees List</field>
        <field name="res_model">day.wise.attendances</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="attendance_form" model="ir.ui.view">
        <field name="name">Attendance Form</field>
        <field name="model">day.wise.attendances</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="date"/>
                        <field name="check_in"/>
                        <field name="check_out"/>
                    </group>
                </sheet>
<!--                  <chatter/>-->
            </form>
        </field>
    </record>

    <record id="attendance_list_tree" model="ir.ui.view" >
        <field name="name">Attendance list tree</field>
        <field name="model">day.wise.attendances</field>
        <field name="arch" type="xml">
            <list>
                          <field name="employee_id"/>
                        <field name="date"/>
                        <field name="check_in"/>
                        <field name="check_out"/>
            </list>
        </field>
    </record>

</odoo>