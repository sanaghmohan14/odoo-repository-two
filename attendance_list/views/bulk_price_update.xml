<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_bulk_price" model="ir.actions.act_window">

        <field name="name">Bulk Price Update</field>
        <field name="res_model">bulk.price</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="bulk_price_form" model="ir.ui.view">
        <field name="name">bulk price from</field>
        <field name="model">bulk.price</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button type="object" string="Apply change"/>
                </header>
                <sheet>
                    <group>
                        <field name="product_ids" widget="many2many_tags"/>
                        <field name="price_update_type" />
                        <field name="product_price"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>