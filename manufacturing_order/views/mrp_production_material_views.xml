<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_mrp_production_material" model="ir.actions.act_window">

        <field name="name">Mrp production material</field>
        <field name="res_model">mrp.production.material</field>
        <field name="view_mode">list,form</field>
    </record>


        <record id="mrp_production_material_form" model="ir.ui.view">
        <field name="name">mrp production material form</field>
        <field name="model">mrp.production.material</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="production_id"/>
                        <field name="product_id" />
                        <field name="required_qty"/>
                        <field name="available_qty"/>
                        <field name="consumed_qty"/>
<!--                        <field name="is_material_available"/>-->
                    </group>

                </sheet>
            </form>
        </field>
    </record>
    <record id="mrp_production_material_tree" model="ir.ui.view">
        <field name="name">mrp production</field>
        <field name="model">mrp.production.material</field>
        <field name="arch" type="xml">
            <list>
                <field name="production_id"/>
                <field name="product_id"/>
                <field name="required_qty"/>
                <field name="available_qty"/>
                <field name="consumed_qty"/>
            </list>
        </field>
    </record>


</odoo>