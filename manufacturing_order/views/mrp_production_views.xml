<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_mrp_production" model="ir.actions.act_window">

        <field name="name">Mrp production </field>
        <field name="res_model">mrp.production.ext</field>
        <field name="view_mode">list,form</field>
    </record>

        <record id="mrp_production_new" model="ir.ui.view">
        <field name="name">mrp production form</field>
        <field name="model">mrp.production.ext</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" options="{'clickable':'1'}" type="object"/>
                    <button string="confirm " name="action_confirm" type="object" invisible="state != 'draft'"/>
                    <button string="start" name="action_start" type="object"/>
                    <button string="cancel" name="action_cancel" type="object" />
                    <button string="consume material" name="action_consume_material" type="object"  invisible="state != 'inprogress'"/>
<!--                    <button string="start production" type="object" name="action_start_production"/>-->
                    <button string="Mark as done" type="object" name="action_done"/>

                </header>
                <sheet>
                       <div name="button_box" class="oe_button_box">
                            <button class="oe_stat_button"
                                    type="object" icon="fa-wrench" name="action_view_material">
                                <div class="o_stat_info">
                                    <field name="material_counts"/>
                                    <field name="material_history" widget="statinfo" string="Materals"/>
                                </div>
                            </button>
                       </div>
                       <group>
                        <h2>
                            <field name="name" readonly="1"/>

                        </h2>
                    </group>
                    <group>
                        <field name="name"/>
                        <field name="product_id" domain="[('is_manufacturable','=',True)]"/>
                        <field name="bom_id"/>
                        <field name="quantity"/>
                        <field name="planned_date"/>
<!--                        <field name="is_material_available"/>-->
                    </group>
                     <notebook>
                        <page  string="products">
                            <field name="material_line_ids">
                            <list editable="bottom">
                                <field name="product_id" />
                                <field name="required_qty"/>
                                <field name="available_qty"/>
                                <field name="consumed_qty"/>
                            </list>

                            </field>


                        </page>
<!--                        <page string="checklists">-->

<!--                            <field name="checklist_ids">-->
<!--                                <list editable="bottom">-->
<!--                                    <field name="order_id"/>-->
<!--                                    <field name="task_name"/>-->
<!--                                    <field name="is_done"/>-->
<!--                                </list>-->
<!--                            </field>-->
<!--                        </page>-->
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>
    <record id="mrp_production_tree" model="ir.ui.view">
        <field name="name">mrp production</field>
        <field name="model">mrp.production.ext</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="product_id"/>
                <field name="bom_id"/>
                <field name="quantity"/>
                <field name="planned_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>



</odoo>