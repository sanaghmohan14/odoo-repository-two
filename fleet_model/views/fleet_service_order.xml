<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_fleet_service_order" model="ir.actions.act_window">

        <field name="name">Fleet Service Order</field>
        <field name="res_model">fleet.service.order</field>
        <field name="view_mode">list,form</field>
    </record>


    <record id="fleet_service_order_from" model="ir.ui.view">
        <field name="name">fleet service order form</field>
        <field name="model">fleet.service.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button string="confirm" type="object" name="action_confrim"/>
                    <button string="Start Service" type="object" name="action_start_service" />
                    <button string="Generate Checklist" type="object"  name="generate_checklist" invisible="state not in ['confirmed']" />
                    <button string="cancel"  type="object" name="action_cancel" invisible="state  in ['done']"/>
                    <field name="state" widget="statusbar" options="{'clickable':'1'}" type="object"/>
                </header>
                <sheet>
                    <group>
                        <h2>
                            <field name="name" readonly="1"/>

                        </h2>
                    </group>
                    <group>
                        <field name="name"/>
                        <field name="vehicle_id" domain="[('service_blocked','=',False)]"/>
                        <field name="technician_id" domain="[('is_available_technician', '=', True)]" />
                        <field name="service_date"/>
                        <field name="state"/>
                        <field name="labor_cost"/>
                        <field name="type_ids" widget="many2many_tags"/>
                        <field name="parts_total"/>
                        <field name="grand_total"/>
                        <field name="checklist_progress"/>

<!--                        <field name="part_ids"  widget="many2many_tags"/>-->
<!--                        <field name="checklist_ids"  widget="many2many_tags"/>-->
                    </group>

                    <notebook>
                        <page  string="parts">
                            <field name="part_ids">
                            <list editable="bottom">
                                <field name="product_id"/>
                                <field name="quantity"/>
                                <field name="unit_price"/>
                            </list>

                            </field>


                        </page>
                        <page string="checklists">

                            <field name="checklist_ids">
                                <list editable="bottom">
                                    <field name="order_id"/>
                                    <field name="task_name"/>
                                    <field name="is_done"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="fleet_service_checklist_tree" model="ir.ui.view" >
        <field name="name">fleet service check list tree</field>
        <field name="model">fleet.service.order</field>
        <field name="arch" type="xml">
            <list>
                        <field name="name"/>
                        <field name="vehicle_id"/>
                        <field name="technician_id" />
                        <field name="service_date"/>
                        <field name="state"/>
            </list>
        </field>
    </record>
</odoo>