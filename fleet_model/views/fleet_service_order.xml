<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_fleet_service_order" model="ir.actions.act_window">

        <field name="name">Fleet Service Order</field>
        <field name="res_model">fleet.service.order</field>
        <field name="view_mode">list,form</field>
    </record>


    <record id="fleet_service_order_from" model="ir.ui.view">
        <field name="name">fleet service order form</field>
        <field name="model">fleet.service.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" options="{'clickable':'1'}" type="object"/>
                </header>
                <sheet>
                    <group>
                        <h2>
                            <field name="name" readonly="1"/>

                        </h2>
                    </group>
                    <group>
                        <field name="name"/>
                        <field name="vehicle_id"/>
                        <field name="technician_id" />
                        <field name="service_date"/>
                        <field name="state"/>
                        <field name="order_part_ids"  widget="many2many_tags"/>
                        <field name="checklist_ids"  widget="many2many_tags"/>
                    </group>

                    <notebook>
                        <page string="parts">
                            <form>
                                <field name="order_part_id"/>
                                <list>

                                </list>


                            </form>
                        </page>
                    </notebook>






                </sheet>
            </form>
        </field>
    </record>

    <record id="fleet_service_checklist_tree" model="ir.ui.view" >
        <field name="name">fleet service check list tree</field>
        <field name="model">fleet.service.order</field>
        <field name="arch" type="xml">
            <list>
                        <field name="name"/>
                        <field name="vehicle_id"/>
                        <field name="technician_id" />
                        <field name="service_date"/>
                        <field name="state"/>
            </list>
        </field>
    </record>
</odoo>