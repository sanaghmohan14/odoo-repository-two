<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_fleet_service_order_part" model="ir.actions.act_window">

        <field name="name">Fleet Service Order part</field>
        <field name="res_model">fleet.service.order.part</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="fleet_service_parts_form" model="ir.ui.view">
        <field name="name">fleet service part form</field>
        <field name="model">fleet.service.order.part</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="order_id"/>
                        <field name="product_id"/>
                        <field name="quantity"/>
                        <field name="unit_price"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <record id="fleet_service_parts_tree" model="ir.ui.view">
        <field name="name">fleet service part tree</field>
        <field name="model">fleet.service.order.part</field>
        <field name="arch" type="xml">
            <list>
                <field name="order_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="unit_price"/>
            </list>
        </field>
    </record>
</odoo>